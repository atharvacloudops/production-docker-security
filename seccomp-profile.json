        "rt_sigprocmask", "ioctl", "access", "execve", "exit",
        "futex", "uname", "getcwd", "chdir", "getpid", "getuid",
        "socket", "connect", "sendto", "recvfrom", "bind",
        "listen", "accept", "setsockopt", "getsockopt", "clone",
        "wait4", "kill", "openat", "readlinkat", "exit_group"
      ],
      "action": "SCMP_ACT_ALLOW"
    }
  ]
}